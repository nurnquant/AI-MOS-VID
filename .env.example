# AIVS local environment template. Copy to .env and adjust.
# NEVER commit .env — only this example file is tracked.

# Application
NODE_ENV=development
APP_URL=http://localhost:3000
LOG_LEVEL=debug

# Database (local Docker defaults — not production credentials)
DATABASE_URL=postgresql://aivs:aivs_local@localhost:5433/aivs
POSTGRES_USER=aivs
POSTGRES_PASSWORD=aivs_local
POSTGRES_DB=aivs
POSTGRES_PORT=5433

# Redis
REDIS_URL=redis://localhost:6380
REDIS_PORT=6380

# Object Storage (local MinIO defaults — not production credentials)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=aivs-assets
S3_ACCESS_KEY_ID=aivs_local
S3_SECRET_ACCESS_KEY=aivs_local_secret
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=aivs_local
MINIO_ROOT_PASSWORD=aivs_local_secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Future providers — leave empty locally. Fill only with user approval,
# never commit real values.
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
VEO_API_KEY=
KLING_API_KEY=
RUNWAY_API_KEY=
ELEVENLABS_API_KEY=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
