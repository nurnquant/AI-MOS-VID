{
  "name": "@aivs/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset --force --skip-seed",
    "db:seed": "node --env-file-if-exists=../../.env src/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.4.0"
  },
  "devDependencies": {
    "dotenv-cli": "^10.0.0",
    "prisma": "^7.4.0",
    "vitest": "^4.1.10"
  }
}
